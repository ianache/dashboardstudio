# .env-ai-analyst — AI Analyst microservice configuration
# Copy to .env-ai-analyst and fill in real values.

# Google AI Studio API key — get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Set to FALSE to use Gemini API key (not Vertex AI Application Default Credentials)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Gemini model to use — gemini-2.0-flash is fast and cost-efficient
GEMINI_MODEL=gemini-2.0-flash
