# BI Portal Backend - Environment Configuration
# Copy this file to .env and configure as needed

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=biportal
POSTGRES_PASSWORD=biportal
POSTGRES_DB=biportal
POSTGRES_SCHEMA=biportal

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=Apps
KEYCLOAK_CLIENT_ID=bi-backend
KEYCLOAK_CLIENT_SECRET=

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false