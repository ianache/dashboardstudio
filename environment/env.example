# =============================================
#  BI Portal Environment Configuration
#  Copia este archivo como .env y ajusta los valores
# =============================================

# ─────────────────────────────────────────────
# PostgreSQL (comparte analytics + keycloak + biportal)
# ─────────────────────────────────────────────
POSTGRES_DB=analytics
POSTGRES_USER=cubeuser
POSTGRES_PASSWORD=cambia_esta_contraseña

# Base de datos y usuario para BI Portal
POSTGRES_BI_DB=biportal
POSTGRES_BI_USER=biportal
POSTGRES_BI_PASSWORD=biportal_password

# ─────────────────────────────────────────────
# Keycloak
# ─────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_DB_NAME=keycloak
KC_DB_USER=keycloak_user
KC_DB_PASSWORD=keycloakpassword
KC_REALM=Apps

# ─────────────────────────────────────────────
# CubeJS
# ─────────────────────────────────────────────
CUBEJS_API_SECRET=genera_un_secreto_largo_y_aleatorio_aqui
NODE_ENV=development
CUBEJS_DEV_MODE=true

# Playground auth (dejar vacío para dev, requerido en prod)
CUBEJS_PLAYGROUNDAUTH=

# ─────────────────────────────────────────────
# BI Backend (FastAPI)
# ─────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KC_CLIENT_SECRET=