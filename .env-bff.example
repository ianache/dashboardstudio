# BFF Service Configuration
# Copy to .env-bff and fill in values — never commit .env-bff

# Server
BFF_PORT=3001

# Session (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BFF_SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Keycloak
# Register confidential client 'dashboard-bff' in Keycloak admin console first
BFF_KEYCLOAK_URL=https://oauth2.qa.comsatel.com.pe
BFF_KEYCLOAK_REALM=Apps
BFF_KEYCLOAK_CLIENT_ID=dashboard-bff
BFF_KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret-from-admin-console

# Callback URL — must match the redirect URI registered in Keycloak
# Local dev (Vite proxy): http://localhost:3000/bff/auth/callback
# Docker / production:    https://dashboard-bff.pm.comsatel.com.pe/bff/auth/callback
BFF_CALLBACK_URL=http://localhost:3000/bff/auth/callback

# Frontend URL — where to redirect after login/logout
FRONTEND_URL=http://localhost:3000

# Upstream services
# Local dev (backend port must be exposed in docker-compose — see ports: "8000:8000"):
BFF_BACKEND_URL=http://localhost:8000
BFF_CUBEJS_URL=http://localhost:4000
BFF_AI_URL=http://localhost:8001

# Docker / production (services reachable via internal network names):
# BFF_BACKEND_URL=http://backend:8000
# BFF_CUBEJS_URL=http://cubejs:4000
# BFF_AI_URL=http://ai-analyst:8001

# CubeJS JWT signing — must match CUBEJS_API_SECRET in your CubeJS service
BFF_CUBEJS_SECRET=your-cubejs-jwt-secret

# CORS — origins the BFF will accept credentials from
BFF_SPA_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis — session store
# Local dev (external Redis): redis://192.168.100.254:6379
# Docker (compose redis service): redis://redis:6379
BFF_REDIS_URL=redis://192.168.100.254:6379
BFF_REDIS_PASSWORD=eYVX7EwVmmxKPCDmwMtyKVge8oLd2t81
BFF_REDIS_PREFIX=bff:sess:

# Cookie settings
# BFF_COOKIE_SECURE=false   # set true in production (HTTPS only)
# BFF_COOKIE_DOMAIN=        # leave unset for localhost dev

# PostgreSQL — application DB (optional if sessions are in Redis)
BFF_POSTGRES_HOST=localhost
BFF_POSTGRES_PORT=5432
BFF_POSTGRES_DB=biportal
BFF_POSTGRES_USER=biportal
BFF_POSTGRES_PASSWORD=your-db-password
BFF_POSTGRES_SCHEMA=biportal
